DERMAVISION_ENV=development
DERMAVISION_DATA_DIR=data
DERMAVISION_CONFIG_PATH=configs/config.yaml
DERMAVISION_DATABASE_URL=sqlite+aiosqlite:///./dermavision.db
DERMAVISION_MODEL_DIR=models/checkpoints
DERMAVISION_DEFAULT_MODEL=efficientnet_b0
DERMAVISION_MODEL_CHECKPOINT=
DERMAVISION_MAX_UPLOAD_MB=10
DERMAVISION_ALLOWED_EXTENSIONS=.png,.jpg,.jpeg
DERMAVISION_MLFLOW_TRACKING_URI=mlruns
DERMAVISION_HOST=0.0.0.0
DERMAVISION_PORT=8000
